
<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Undangan Haji</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>

<style>

/* RESET TOTAL */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* FULL SCREEN PAKSA */
html, body {
  width: 100vw;
  height: 100dvh;
  overflow: hidden;
  background: #000;
  font-family: 'Poppins', sans-serif;
}

/* TEMBUS MYBIOLINK */
body {
  position: fixed;
  inset: 0;
}

/* OPENING */
#opening {
  position: fixed;
  inset: 0;
  background: url('https://images.unsplash.com/photo-1584551246679-0daf3d275d0f') center/cover no-repeat;
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
  z-index: 9999;
}

#opening::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.7);
}

.open-box {
  position: relative;
  z-index: 2;
  padding: 20px;
}

.open-box h1 {
  color: #fff;
  font-family: 'Playfair Display';
  font-size: 32px;
}

.open-box p {
  color: #fff;
}

/* BUTTON */
.btn {
  margin-top: 20px;
  padding: 14px 30px;
  border-radius: 40px;
  border: none;
  background: gold;
  font-weight: bold;
}

/* SWIPER FULL */
.swiper, .swiper-wrapper, .swiper-slide {
  width: 100vw;
  height: 100dvh;
}

.swiper-slide {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* BACKGROUND ANTI SPACE */
.bg {
  position: fixed;
  top: -5%;
  left: -5%;
  width: 110vw;
  height: 110dvh;
  background-size: cover;
  background-position: center;
  filter: brightness(0.35);
}

/* OVERLAY */
.swiper-slide::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.95) 30%,
    rgba(0,0,0,0.7) 60%,
    rgba(0,0,0,0.3)
  );
}

/* CONTENT */
.content {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  padding: 20px;
  padding-bottom: 120px;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  text-align: center;
}

/* TEXT PUTIH JELAS */
.content span {
  color: #fff;
  font-size: 20px;
  text-shadow:
    0 2px 6px rgba(0,0,0,0.9),
    0 0 10px rgba(0,0,0,0.8);
}

.content span:nth-child(2) {
  font-size: 26px;
  font-weight: bold;
}

/* NAV */
.nav {
  position: fixed;
  bottom: 0;
  width: 100%;
  height: 70px;
  background: rgba(0,0,0,0.9);
  display: flex;
  justify-content: space-around;
  align-items: center;
  z-index: 999;
}

.nav a {
  color: #aaa;
  text-decoration: none;
  font-size: 12px;
}

.nav a.active {
  color: gold;
}

/* ANIMASI */
.fade span {
  opacity: 0;
  transform: translateY(30px);
  animation: fadeUp .8s forwards;
}

.fade span:nth-child(1){animation-delay:.3s}
.fade span:nth-child(2){animation-delay:.6s}
.fade span:nth-child(3){animation-delay:.9s}

@keyframes fadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

</style>
</head>

<body style="margin:0!important;padding:0!important;">

<!-- OPENING -->
<div id="opening">
  <div class="open-box">
    <p>Undangan Syukuran Haji</p>
    <h1>Bapak & Ibu Ahmad</h1>
    <p id="nama"></p>
    <button class="btn" onclick="buka()">Buka Undangan</button>
  </div>
</div>

<!-- AUDIO -->
<audio id="musik" loop>
  <source src="https://www.bensound.com/bensound-music/bensound-slowmotion.mp3">
</audio>

<!-- SLIDER -->
<div class="swiper">
  <div class="swiper-wrapper">

    <div class="swiper-slide">
      <div class="bg" style="background-image:url('https://images.unsplash.com/photo-1564769625392-651b2a0b3d7f')"></div>
      <div class="content fade">
        <span>Assalamu’alaikum</span>
        <span>Dengan penuh syukur</span>
        <span>Kami mengundang Anda</span>
      </div>
    </div>

    <div class="swiper-slide">
      <div class="bg" style="background-image:url('https://images.unsplash.com/photo-1506784983877-45594efa4cbe')"></div>
      <div class="content fade">
        <span>Tuan Rumah</span>
        <span>Bapak & Ibu Ahmad</span>
      </div>
    </div>

    <div class="swiper-slide">
      <div class="bg" style="background-image:url('https://images.unsplash.com/photo-1584551246679-0daf3d275d0f')"></div>
      <div class="content fade">
        <span>10 Oktober 2026</span>
        <span>10.00 WITA</span>
        <span>Denpasar</span>
      </div>
    </div>

    <div class="swiper-slide">
      <div class="bg" style="background-image:url('https://images.unsplash.com/photo-1578926375605-eaf7559b1458')"></div>
      <div class="content fade">
        <span>Konfirmasi Kehadiran</span>
        <button class="btn" onclick="wa()">WhatsApp</button>
      </div>
    </div>

  </div>
</div>

<!-- NAV -->
<div class="nav">
  <a onclick="go(0)" class="active">Home</a>
  <a onclick="go(1)">Tuan</a>
  <a onclick="go(2)">Acara</a>
  <a onclick="go(3)">RSVP</a>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>

/* AMBIL NAMA TAMU */
const p = new URLSearchParams(window.location.search);
document.getElementById('nama').innerText = p.get('to') || 'Tamu Undangan';

/* BUKA */
function buka(){
  document.getElementById('opening').style.display='none';
  document.getElementById('musik').play().catch(()=>{});
}

/* WA */
function wa(){
  window.open('https://wa.me/6281234567890');
}

/* SLIDER */
const swiper = new Swiper('.swiper', {
  direction: 'vertical',
  speed: 900,
  mousewheel: true,
  on:{
    slideChange:function(){
      setActive(this.activeIndex);
    }
  }
});

/* NAV */
function go(i){
  swiper.slideTo(i);
}

function setActive(i){
  document.querySelectorAll('.nav a').forEach((el,idx)=>{
    el.classList.toggle('active', idx === i);
  });
}

</script>

</body>
</html>
